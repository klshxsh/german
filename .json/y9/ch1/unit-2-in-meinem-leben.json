{
  "unit": {
    "name": "In meinem Leben",
    "description": "Talking about what you have done in your life using the perfect tense"
  },
  "categories": [
    {
      "id": "cat_1",
      "name": "Perfect tense - haben conjugation",
      "description": "Conjugation of haben in the present tense for forming the perfect tense",
      "grammarNotes": "Used with most verbs to form the perfect tense. Structure: subject + haben conjugation + past participle at end of clause"
    },
    {
      "id": "cat_2",
      "name": "Perfect tense - sein conjugation",
      "description": "Conjugation of sein in the present tense for forming the perfect tense",
      "grammarNotes": "Used with verbs of motion and change of state to form the perfect tense. Structure: subject + sein conjugation + past participle at end of clause"
    },
    {
      "id": "cat_3",
      "name": "Activities with haben - basic",
      "description": "Common activities in the perfect tense using haben",
      "grammarNotes": "Perfect tense formed with haben + past participle"
    },
    {
      "id": "cat_4",
      "name": "Activities with sein - motion and change",
      "description": "Activities in the perfect tense using sein (verbs of motion and becoming)",
      "grammarNotes": "Perfect tense formed with sein + past participle. Used for verbs of motion (fahren, laufen) and change of state (werden)"
    },
    {
      "id": "cat_5",
      "name": "More activities - haben perfect tense",
      "description": "Extended activities using haben in the perfect tense",
      "grammarNotes": "Perfect tense with haben. Can include time phrases which cause verb flip-flop (time phrase + auxiliary + subject + past participle)"
    },
    {
      "id": "cat_6",
      "name": "More activities - achievements",
      "description": "Activities and achievements in the perfect tense",
      "grammarNotes": "Perfect tense constructions. Time phrases at the beginning cause inversion (verb-subject order)"
    },
    {
      "id": "cat_7",
      "name": "Connectives",
      "description": "Connecting words to link clauses and ideas",
      "grammarNotes": "denn = coordinating (no word order change); weil/da/obwohl = subordinating (verb to end of clause)"
    },
    {
      "id": "cat_8",
      "name": "Opinions",
      "description": "Phrases for expressing opinions",
      "grammarNotes": "Opinion starters that can be followed by adjectives or full clauses with dass"
    },
    {
      "id": "cat_9",
      "name": "Qualifiers and adjectives - positive",
      "description": "Positive qualifiers and adjectives to describe experiences and people",
      "grammarNotes": "Qualifiers modify adjectives; adjectives can describe experiences or people"
    },
    {
      "id": "cat_10",
      "name": "Qualifiers and adjectives - negative",
      "description": "Negative qualifiers and adjectives",
      "grammarNotes": "Used to express negative opinions or describe negative qualities"
    },
    {
      "id": "cat_11",
      "name": "Qualifiers - intensity",
      "description": "Adverbs that modify the intensity of adjectives",
      "grammarNotes": "Place before adjectives to indicate degree"
    },
    {
      "id": "cat_12",
      "name": "Adjectives - personality positive",
      "description": "Positive personality traits",
      "grammarNotes": "Can be used with sein to describe people"
    },
    {
      "id": "cat_13",
      "name": "Adjectives - personality negative",
      "description": "Negative personality traits",
      "grammarNotes": "Can be used with sein to describe people"
    }
  ],
