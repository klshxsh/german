{
  "unit": {
    "name": "Meine Kindheit - Sonnet 4.6 - Reviewed",
    "description": "My childhood - discussing past experiences, favorite things, and future aspirations"
  },
  "categories": [
    {
      "id": "cat_1",
      "name": "Time phrases - childhood",
      "description": "Temporal expressions for talking about childhood",
      "grammarNotes": "Used with imperfect tense (war, hatte) to set the time context"
    },
    {
      "id": "cat_2",
      "name": "Possessions in childhood",
      "description": "Things one had as a child",
      "grammarNotes": "Used with 'hatte ich' (I had). Note accusative case markers: einen (masculine), eine (feminine), ein (neuter), viele (plural)"
    },
    {
      "id": "cat_3",
      "name": "Personal qualities in childhood",
      "description": "Adjectives describing how one was as a child",
      "grammarNotes": "Used with 'war ich' (I was)"
    },
    {
      "id": "cat_4",
      "name": "Connectives",
      "description": "Connecting words and phrases for complex sentences",
      "grammarNotes": "weil/da/obwohl/obschon/obgleich send the verb to the end of the clause"
    },
    {
      "id": "cat_5",
      "name": "Opinion phrases",
      "description": "Expressions for giving opinions about the past",
      "grammarNotes": "Used to introduce evaluative statements"
    },
    {
      "id": "cat_6",
      "name": "Positive qualifiers",
      "description": "Positive adjectives for describing experiences",
      "grammarNotes": "Adjectives used to evaluate past experiences positively"
    },
    {
      "id": "cat_7",
      "name": "Negative qualifiers",
      "description": "Negative adjectives for describing experiences",
      "grammarNotes": "Adjectives used to evaluate past experiences negatively"
    },
    {
      "id": "cat_8",
      "name": "Meine Lieblingssachen - time phrases",
      "description": "Time phrases for discussing favorite things",
      "grammarNotes": "Temporal expressions used when talking about favorite things in childhood"
    },
    {
      "id": "cat_9",
      "name": "Meine Lieblingssachen - sentence starters",
      "description": "Sentence structures for stating favorite things",
      "grammarNotes": "Used with 'war' (was) or 'waren' (were) depending on the subject"
    },
    {
      "id": "cat_10",
      "name": "Favorite foods",
      "description": "Common favorite foods from childhood",
      "grammarNotes": "Nouns used with 'mein Lieblingsessen'"
    },
    {
