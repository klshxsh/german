    {
      "id": "cat_14",
      "name": "Favorite clothing",
      "description": "Favorite items of clothing",
      "grammarNotes": "Used with 'mein Lieblingskleidungstück'. Note gender: mein (masculine/neuter), meine (feminine)"
    },
    {
      "id": "cat_15",
      "name": "Future - conditional phrases",
      "description": "Conditional and temporal phrases for talking about the future",
      "grammarNotes": "Wenn-clauses. 'Wenn ich ... hätte' uses subjunctive II (Konjunktiv II)"
    },
    {
      "id": "cat_16",
      "name": "Future - main clause starters",
      "description": "Phrases to express future intentions",
      "grammarNotes": "Used with würde + infinitive or möchte + infinitive"
    },
    {
      "id": "cat_17",
      "name": "Future - activities",
      "description": "Things one would like to do in the future",
      "grammarNotes": "Infinitive phrases used with würde/möchte"
    },
    {
      "id": "cat_18",
      "name": "Future - connectives",
      "description": "Connectives for explaining future plans",
      "grammarNotes": "weil/obwohl/obschon/obgleich send verb to end. 'was' is a relative pronoun"
    },
    {
      "id": "cat_19",
      "name": "Future - descriptive adjectives",
      "description": "Adjectives describing future experiences",
      "grammarNotes": "Used with 'sein wird' (will be)"
    }
