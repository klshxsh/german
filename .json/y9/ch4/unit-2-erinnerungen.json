{
  "unit": {
    "name": "Erinnerungen",
    "description": "Memories - Talking about childhood, past abilities, and reflections on growing up"
  },
  "categories": [
    {
      "id": "cat_1",
      "name": "Time Phrases - Age and Life Stages",
      "description": "Expressions for talking about different ages and times in the past and present",
      "grammarNotes": "Uses 'mit' + dative for age expressions, 'als' clauses for past events"
    },
    {
      "id": "cat_2",
      "name": "Modal Verbs - können",
      "description": "Past and present forms of können (can/could) - ability",
      "grammarNotes": "Preterite: konnte/konnten; Present: kann/können"
    },
    {
      "id": "cat_3",
      "name": "Modal Verbs - dürfen",
      "description": "Past and present forms of dürfen (to be allowed to)",
      "grammarNotes": "Preterite: durfte/durften; Present: darf/dürfen"
    },
    {
      "id": "cat_4",
      "name": "Modal Verbs - müssen",
      "description": "Past and present forms of müssen (to have to/must)",
      "grammarNotes": "Preterite: musste/mussten; Present: muss/müssen"
    },
    {
      "id": "cat_5",
      "name": "Activities - Abilities",
      "description": "Infinitive verbs describing childhood abilities and activities",
      "grammarNotes": "Used with modal verbs (konnte, kann, etc.)"
    },
    {
      "id": "cat_6",
      "name": "Activities - Permissions and Obligations",
      "description": "Infinitive phrases describing what one was/is allowed or required to do",
      "grammarNotes": "Used with dürfen and müssen"
    },
    {
      "id": "cat_7",
      "name": "Opinion Phrases and Qualifiers",
      "description": "Sentence starters and adverbs for expressing opinions and qualifying statements",
      "grammarNotes": "Can be used as sentence introducers or adverbs"
    },
    {
      "id": "cat_8",
      "name": "Adjectives - Evaluations",
      "description": "Adjectives for evaluating childhood and life experiences",
      "grammarNotes": "Used predicatively after 'war' or attributively with noun endings"
    },
    {
      "id": "cat_9",
      "name": "Connectives - Reasons",
      "description": "Conjunctions for giving reasons and explanations",
      "grammarNotes": "denn = coordinating (verb second); weil/da/obwohl = subordinating (verb final)"
    },
    {
      "id": "cat_10",
      "name": "Reason Phrases",
      "description": "Complete sentence phrases explaining why childhood was good or bad",
      "grammarNotes": "Used after subordinating conjunctions or as independent statements"
    }
  ],
