{
  "unit": {
    "name": "Wahnsinn! Discussing crazy ambitions",
    "description": "A unit focused on discussing extreme activities, ambitions, and hypothetical situations using the conditional tense (würde) and personality adjectives"
  },
  "categories": [
    {
      "id": "cat_1",
      "name": "Personality Adjectives",
      "description": "Adjectives describing personality traits related to bravery and adventure",
      "grammarNotes": "Used with 'Bist du...?' and 'Ich bin...' constructions"
    },
    {
      "id": "cat_2",
      "name": "Qualifiers and Intensifiers",
      "description": "Adverbs that modify adjectives to show degree or intensity",
      "grammarNotes": "Used before adjectives to indicate how much of that quality someone has"
    },
    {
      "id": "cat_3",
      "name": "Time Phrases",
      "description": "Temporal expressions used at the beginning of sentences",
      "grammarNotes": "When placed at the beginning of a sentence, these cause verb-subject inversion (FLIP FLOP THE VERB AND PRONOUN)"
    },
    {
      "id": "cat_4",
      "name": "Conditional Mood - würde",
      "description": "Conditional forms expressing what one would do",
      "grammarNotes": "Formed with würde + infinitive at the end of the clause. Conjugates like a modal verb."
    },
    {
      "id": "cat_5",
      "name": "Conditional Phrases with würde",
      "description": "Common phrases using the conditional mood",
      "grammarNotes": "Express willingness, likelihood, or preference in hypothetical situations"
    },
    {
      "id": "cat_6",
      "name": "Extreme Activities",
      "description": "Verbs and phrases describing adventurous or extreme activities",
      "grammarNotes": "Infinitive forms used after würde in conditional sentences"
    },
    {
      "id": "cat_7",
      "name": "Preparation and Training Activities",
      "description": "Activities related to preparing for extreme challenges",
      "grammarNotes": "Infinitive forms used after würde"
    },
    {
      "id": "cat_8",
      "name": "Reflexive Verbs - Conditional",
      "description": "Reflexive pronouns used with würde for self-referential actions",
      "grammarNotes": "Reflexive pronoun changes with subject: mich, dich, sich, uns, euch, sich"
    },
    {
      "id": "cat_9",
      "name": "Reflexive Verb Activities",
      "description": "Reflexive verbs describing preparation and emotional states",
      "grammarNotes": "Used with reflexive pronouns and würde for conditional meaning"
    },
    {
      "id": "cat_10",
      "name": "Reasons and Opinions",
      "description": "Phrases expressing reasons for or against doing extreme activities",
      "grammarNotes": "Often used with subordinating conjunctions like weil, da, obwohl"
    },
    {
      "id": "cat_11",
      "name": "High Frequency Words",
      "description": "Common words and small grammatical elements",
      "grammarNotes": "Includes negations, prepositions, and other functional words"
    },
    {
      "id": "cat_12",
      "name": "Subordinating Conjunctions",
      "description": "Conjunctions that send the verb to the end of the clause",
      "grammarNotes": "weil/da (because) and obwohl/obschon (although) require verb-final word order"
    }
  ],
