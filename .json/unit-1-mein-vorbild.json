{
  "unit": {
    "name": "Describing Role Models",
    "description": "A worksheet focused on describing role models using present and perfect tenses, qualifiers, adjectives, opinions, and connectives"
  },
  "categories": [
    {
      "id": "cat_1",
      "name": "Opening Phrases",
      "description": "Introductory phrases to introduce and express feelings about role models",
      "grammarNotes": "Basic sentence structures for introducing role models"
    },
    {
      "id": "cat_2",
      "name": "Qualifiers & Adjectives",
      "description": "Qualifiers to modify intensity and adjectives to describe personality traits",
      "grammarNotes": "Qualifiers modify adjectives; adjectives describe characteristics of role models"
    },
    {
      "id": "cat_3",
      "name": "Connectives",
      "description": "Connecting words to link ideas and clauses",
      "grammarNotes": "weil, da, obwohl, obschon, obgleich send the verb to the end of the clause"
    },
    {
      "id": "cat_4",
      "name": "Activities: Present Tense",
      "description": "Describing what role models do using present tense verbs",
      "grammarNotes": "Present tense descriptions of activities; time phrases cause verb-subject inversion"
    },
    {
      "id": "cat_5",
      "name": "Activities: Perfect Tense",
      "description": "Describing what role models have done using perfect tense",
      "grammarNotes": "Perfect tense with haben or sein as auxiliary; time phrases cause verb-subject inversion"
    },
    {
      "id": "cat_6",
      "name": "Opinions",
      "description": "Opinion phrases and evaluative adjectives",
      "grammarNotes": "Phrases to express personal opinions about role models"
    }
  ],
