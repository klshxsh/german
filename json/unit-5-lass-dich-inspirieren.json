    },
    {
      "id": "cat_7",
      "name": "Adjectives",
      "description": "Descriptive adjectives for people and experiences",
      "grammarNotes": "Adjectives used to describe role models and their qualities"
    },
    {
      "id": "cat_8",
      "name": "Opening Phrases",
      "description": "Starter phrases for discussing role models",
      "grammarNotes": "Present tense phrases introducing the topic"
    }
  ],
